# =============================================================================
# EVM-Mint-BOT — OpenSea Raw Transaction Sniper
# Copy to .env and fill values. NEVER commit real .env.
# =============================================================================

PRIVATE_KEY=***
RPC_URL=https://ethereum-rpc.publicnode.com

NFT_CONTRACT=0xYourNftContract
CHAIN_IDENTIFIER=ethereum
QUANTITY=1

# Raw-only mode. Do not change.
MINT_MODE=opensea_raw
OPENSEA_COLLECTION_SLUG=your-collection-slug
OPENSEA_JWT=eyJ_replace_with_fresh_token

# Safety
DRY_RUN=true
PREFLIGHT_ONLY=false
MAX_MINT_VALUE_ETH=0.5
START_AT=2026-01-01T00:00:00.000Z

# OpenSea polling
OPENSEA_POLLS=120
OPENSEA_POLL_INTERVAL_MS=1000

# Gas ladder: balanced default. Brutal war preset: 700,500,350,250,150
GAS_LIMIT=350000
BASE_FEE_MULTIPLIER=300
MIN_PRIORITY_GWEI=2
MAX_PRIORITY_GWEI=10
FIRE_GAS_TIERS=300,220,160,120

