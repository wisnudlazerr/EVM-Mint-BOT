# Copy to .env and fill with a burner wallet only.
PRIVATE_KEY=0xYOUR_BURNER_PRIVATE_KEY

# Public or private RPC. Do not commit paid/private RPC URLs.
RPC_URL=https://ethereum-rpc.publicnode.com

# Mint target
NFT_CONTRACT=0xYourNftContract
MINT_FUNCTION=mint
QUANTITY=1
VALUE_ETH=0

# Optional allowlist/proof args if contract needs them.
# Leave empty if your mint function only takes quantity.
# Example JSON arrays:
# MINT_ARGS_JSON=["0xproof1","0xproof2"]
MINT_ARGS_JSON=[]

# Timing
START_AT=2026-01-01T00:00:00.000Z
DRY_RUN=true

# Gas controls
GAS_LIMIT=300000
MAX_FEE_GWEI=20
MAX_PRIORITY_FEE_GWEI=2
