PRIVATE_KEY=0xYOUR_BURNER_PRIVATE_KEY
RPC_URL=https://ethereum-rpc.publicnode.com

NFT_CONTRACT=0xYourNftContract
SEADROP_CONTRACT=0xYourSeaDropContract
OPENSEA_SLUG=your-collection-slug
CHAIN_IDENTIFIER=ethereum

QUANTITY=1
MINT_PRICE=0
MAX_MINT_VALUE_ETH=0.5

START_AT=2026-01-01T00:00:00.000Z
DRY_RUN=true
PREFLIGHT_ONLY=false

GAS_LIMIT=350000
BASE_FEE_MULTIPLIER=300
MIN_PRIORITY_GWEI=2
MAX_PRIORITY_GWEI=10

BROADCAST_ROUTE=public
PRIVATE_RELAY_URL=
PRIVATE_RELAY_AUTH_KEY=

# Geber / FCFS allowlist controls
MINT_MODE=allowlist
FIRE_GAS_TIERS=700,500,350,250,150
RETRY_COUNT=120
RETRY_INTERVAL_MS=1000
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# SeaDrop allowlist/signed input. Keep real proof/signature out of git.
MINT_PARAMS_JSON=["0","1","0","4102444800","0","0","0",false]
PROOF_JSON=[]
SALT=
SIGNATURE=

# Direct fallback only if target contract is not SeaDrop.
MINT_FUNCTION=mint
MINT_ARGS_JSON=[1]
